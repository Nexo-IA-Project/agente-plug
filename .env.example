ADMIN_PASSWORD=# senha do usuário admin inicial (gerada no primeiro deploy)
ADMIN_ACCOUNT_ID=1
JWT_SECRET=# gere com: python -c "import secrets; print(secrets.token_hex(32))"
META_API_KEY=changeme
META_WABA_ID=  # ID da conta WABA no Meta Business (para templates WhatsApp)
INTEGRATION_CREDENTIALS_KEY=# gere com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
